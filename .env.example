AUTH_SECRET=replace-with-a-long-random-string

# Base URL of the app (required for OAuth redirects). Local dev:
NEXTAUTH_URL=http://localhost:3000

AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret

AUTH_DEMO_EMAIL=demo@bandsaround.app
AUTH_DEMO_PASSWORD=demo-password-change-me

# Spotify Web API (account linking — Dashboard → app → Redirect URIs must match exactly)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/integrations/spotify/callback

# Last.fm API (create key at last.fm/api/account/create — set Authorized callback URL)
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_REDIRECT_URI=http://localhost:3000/api/integrations/lastfm/callback
